# MyFitnessPal Session Cookies
# Copy this file to .env and fill in your values
# Export these from your browser after logging into MyFitnessPal
# See README.md for instructions on how to export cookies

# Required: Your MFP session cookie value
MFP_SESSION_COOKIE=your_session_cookie_value_here

# Optional: Your MFP username (for verification)
MFP_USERNAME=your_username



